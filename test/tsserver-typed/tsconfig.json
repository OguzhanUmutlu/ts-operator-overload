{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "skipLibCheck": true,
    "plugins": [
      {
        "name": "ts-operator-overload",
        "mode": "shadow"
      }
    ]
  },
  "include": [
    "smart-sub-return.ts",
    "eq-string-return.ts",
    "string-return.ts",
    "number-return.ts"
  ]
}
